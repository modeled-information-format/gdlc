{
  "description": "Claude Code progressive-enhancement layer: session bootstrap, MIF-body validation, a legible confirmation prompt before any board mutation, a non-blocking ticket-hygiene reminder (ADR-0007) covering a plugin's own MCP tools, the generic github MCP server, and raw gh CLI calls, and a non-blocking gdlc config-drift check (ADR-0009) at session start. Every behavior here is additive — the portable MCP core (get_session_context, get_agent_capabilities, format_mif_issue_body, get_gdlc_config, write_gdlc_config) is the floor a hook-less host uses instead.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/session-start.mjs"],
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/config-drift-check.mjs"],
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^mcp__(plugin_.+_)?github-sdlc-planning__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/validate-mif.mjs"],
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-check.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "^mcp__(plugin_.+_)?github-sdlc-planning__(add_sub_issue|update_issue)$",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/set-in-progress.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "^(Write|Edit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/set-in-progress.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "mcp__github__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-check.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-check.mjs"],
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^mcp__(plugin_.+_)?github-sdlc-planning__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/confirm-mutation.mjs"],
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-aggregate.mjs"],
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-aggregate.mjs"],
            "timeout": 15
          }
        ]
      }
    ]
  }
}
