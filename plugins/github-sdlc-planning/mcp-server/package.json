{
  "name": "@github-sdlc-plugins/github-sdlc-planning-mcp-server",
  "version": "0.11.3",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": "./dist/index.js",
    "./config": "./dist/config.js",
    "./mif": "./dist/mif.js",
    "./project-profile": "./dist/project-profile.js",
    "./resolvers": "./dist/resolvers.js",
    "./tools/projects": "./dist/tools/projects.js",
    "./tools/config": "./dist/tools/config.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run bundle",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" && esbuild scripts/validate-gdlc-config.ts --bundle --platform=node --format=esm --outfile=dist/validate-gdlc-config.js --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "lint": "eslint src test scripts --max-warnings 0",
    "verify:live": "tsx scripts/verify-live.ts",
    "validate-gdlc-config": "node dist/validate-gdlc-config.js"
  },
  "dependencies": {
    "@github-sdlc-plugins/singleflight-cache": "file:../../../packages/singleflight-cache",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "msw": "^2.15.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
