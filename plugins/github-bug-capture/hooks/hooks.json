{
  "description": "Hooks-pack (issue #39, opt-in via .config/gdlc/config.yml's packs.hooks section): scans Bash tool output and the end-of-turn transcript for common test/lint/build failure signatures, and surfaces the file-bug skill as additionalContext when one is found. Always a safe no-op when the pack is disabled or no failure signature is found; never calls MCP tools itself. Also carries ADR-0007's non-blocking ticket-hygiene reminder (byte-identical copy of github-sdlc-planning's canonical hygiene-check.mjs/hygiene-aggregate.mjs/lib, kept in sync by a build-time drift check), independent of the hooks-pack toggle, and the ADR-0010 session-pointer bootstrap (cwd -> session_id, byte-copied and drift-checked the same way), the bridge this plugin's bug-triage background monitor resolves its session context from.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/session-pointer.mjs"],
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/diagnostic-capture.mjs", "post-tool-use"],
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-check.mjs"],
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/track-created-issues.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "^mcp__(plugin_.+_)?github-bug-capture__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-check.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "mcp__github__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-check.mjs"],
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/track-created-issues.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "^mcp__(plugin_.+_)?github-sdlc-planning__create_issue$",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/track-created-issues.mjs"],
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/diagnostic-capture.mjs", "stop"],
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-aggregate.mjs"],
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-aggregate.mjs"],
            "timeout": 15
          }
        ]
      }
    ]
  }
}
