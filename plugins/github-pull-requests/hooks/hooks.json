{
  "description": "ADR-0007 ticket-hygiene reminder: a non-blocking PostToolUse/Stop/SubagentStop hook covering this plugin's own MCP tools, the generic github MCP server, and raw gh CLI calls. Byte-identical copy of github-sdlc-planning's canonical hygiene-check.mjs/hygiene-aggregate.mjs/lib, kept in sync by a build-time drift check.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^mcp__(plugin_.+_)?github-pull-requests__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-check.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "mcp__github__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-check.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-check.mjs"],
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-aggregate.mjs"],
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/hygiene-aggregate.mjs"],
            "timeout": 15
          }
        ]
      }
    ]
  }
}
